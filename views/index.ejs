<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI Chatbot</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="container">
        <header>
            <h1>🤖 AI Chatbot System</h1>
            <p>Intelligent Assistant with Coding & Research Capabilities</p>
        </header>
        
        <div class="features">
            <div class="feature-card">
                <h3>💻 Code Generation</h3>
                <p>Generate code in any programming language with AI assistance</p>
            </div>
            <div class="feature-card">
                <h3>🔍 Research</h3>
                <p>Search and analyze information from the web</p>
            </div>
            <div class="feature-card">
                <h3>🔧 Code Review</h3>
                <p>Get expert feedback on your code</p>
            </div>
            <div class="feature-card">
                <h3>🛡️ Content Filter</h3>
                <p>Advanced filtering for safe interactions</p>
            </div>
        </div>
        
        <div class="quick-start">
            <h2>Quick Start</h2>
            <div class="example-prompts">
                <button onclick="loadExample('code')">Generate Python Function</button>
                <button onclick="loadExample('research')">Research AI Trends</button>
                <button onclick="loadExample('review')">Review JavaScript Code</button>
            </div>
        </div>
        
        <a href="/chat" class="btn-primary">Start Chatting</a>
    </div>
    
    <script src="/js/main.js"></script>
</body>
</html>